  {
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "modules-left": [
      "wlr/taskbar",
      "mpris",
      "tray"
    ],
    "modules-center": [
      "hyprland/workspaces"
    ],
    "modules-right": [
      "custom/update",
      "network",
      "custom/uptime",
      "cpu",
      "memory",
      "hyprland/language",
      "clock"
    ],
    "hyprland/workspaces": {
      "on-click": "activate",
      "format": "{name}",
      "persistent-workspaces": {
        "HDMI-A-1": [
          1,
          2,
          3,
          4,
          5
        ],
        "DP-1": [
          6,
          7,
          8,
          9,
          10
        ]
      }
    },
    "network": {
      "format-wifi": "󰤢 {bandwidthDownBits}",
      "format-ethernet": "󰈀 {bandwidthDownBits}",
      "format-disconnected": "󰤠 No Network",
      "interval": 5,
      "tooltip": true,
      "tooltip-format": "{ipaddr}"
    },
    "custom/uptime": {
      "format": "{}",
      "interval": 60,
      "exec": "uptime -p | sed -e 's/up //' -e 's/ days\\?, /d /g' -e 's/ hours\\?, /h /g' -e 's/ minutes\\?/m/g'"
    },
    "cpu": {
      "interval": 1,
      "format": "  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
      "format-icons": [
        "▁",
        "▂",
        "▃",
        "▄",
        "▅",
        "▆",
        "▇",
        "█"
      ]
    },
    "custom/update": {
      "format": "",
      "exec": "omarchy-update-available",
      "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
      "tooltip-format": "Omarchy update available",
      "signal": 7,
      "interval": 3600
    },
    "wlr/taskbar": {
      "format": "{icon}",
      "on-click": "activate",
      "icon-size": 18,
      "tooltip-format": "{title}"
    },
    "mpris": {
      "format": "{player_icon} {dynamic}",
      "format-paused": "{status_icon} <i>{dynamic}</i>",
      "player-icons": {
        "default": "",
        "mpv": "🎵",
        "spotify": "",
        "zen": "󰈹",
        "firefox": "󰈹",
        "chromium": ""
      },
      "status-icons": {
        "paused": "󰏤"
      },
      "dynamic-len": 40,
      "dynamic-importance": [
        "title",
        "artist"
      ],
      "dynamic-order": [
        "title",
        "artist"
      ],
      "dynamic-separator": "  ",
      "tooltip-format": "{player} ({status})\n{title}  {artist}\n{album}",
      "interval": 1,
      "on-click": "playerctl play-pause",
      "on-click-middle": "playerctl previous",
      "on-click-right": "playerctl next",
      "on-scroll-up": "playerctl volume 0.05+",
      "on-scroll-down": "playerctl volume 0.05-"
    },
    "memory": {
      "interval": 5,
      "format": "󰍛 {used:0.1f}G/{total:0.1f}G",
      "tooltip-format": "RAM: {used}GB / {total}GB",
      "on-click": "omarchy-launch-or-focus-tui btop"
    },
    "hyprland/language": {
      "format": "{}",
      "format-en": "US",
      "format-ar": "AR"
    },
    "clock": {
      "format": "{:%I:%M:%S %p}",
      "format-alt": "{:%A, %B %d}",
      "interval": 1
    }
  }