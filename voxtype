/* Optimized Voxtype Module */
#custom-voxtype {
    min-width: 16px;
    margin: 0 6px;
    padding: 0 4px;
    font-size: 14px;
}

#custom-voxtype.recording {
    color: #ff5555;
    animation: pulse 1s ease-in-out infinite;
}

#custom-voxtype.transcribing { color: #f1fa8c; }
#custom-voxtype.idle { color: #50fa7b; }
#custom-voxtype.stopped { color: #6272a4; }





#custom-idle-indicator.active,
#custom-notification-silencing-indicator.active {
  color: #a55555;
}
